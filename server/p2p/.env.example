# P2P Signaling Server

# HTTP port to listen on
PORT=4242

# Redis connection URL (optional — falls back to in-memory if unavailable)
REDIS_URL=redis://localhost:6379

# Node TTL in seconds — nodes must re-register before this expires
NODE_TTL_SEC=120

# JWT secret — MUST be changed in production (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret

# GitHub OAuth app credentials (optional — only needed for GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Max API requests per token per 60-second window
RATE_LIMIT_PER_MIN=60
