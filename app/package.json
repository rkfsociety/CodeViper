{
  "type": "module",
  "name": "codeviper",
  "version": "0.1.0",
  "description": "Локальный AI-агент с GUI — чат, файлы и терминал через Ollama",
  "main": "out/main/index.js",
  "author": "roman",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "setup-node": "node ../scripts/download-node.js",
    "dist": "npm run setup-node && electron-vite build && electron-builder",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:load": "vitest run --reporter=verbose tests/load.test.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "bump": "npx tsx ../scripts/bump-version.ts",
    "prepare": "cd .. && husky app/.husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,css}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.codeviper.app",
    "productName": "CodeViper",
    "copyright": "Copyright © 2025 roman",
    "directories": {
      "buildResources": "resources",
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.png",
      "uninstallerIcon": "resources/icon.png",
      "shortcutName": "CodeViper",
      "include": "resources/installer.nsh"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "Development"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "darkModeSupport": true
    },
    "dmg": {
      "sign": false
    },
    "publish": {
      "provider": "github",
      "owner": "rkfsociety",
      "repo": "CodeViper"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@tanstack/react-virtual": "^3.14.3",
    "highlight.js": "^11.11.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "systeminformation": "^5.31.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@playwright/test": "^1.61.0",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^36.3.2",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^3.1.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.8"
  }
}
