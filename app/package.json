{
  "type": "module",
  "name": "codeviper",
  "version": "0.3.76",
  "description": "Локальный AI-агент с GUI — чат, файлы и терминал через Ollama",
  "main": "out/main/index.js",
  "author": "roman",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "setup-node": "node ../scripts/download-node.js",
    "dist": "npm run setup-node && electron-vite build && electron-builder",
    "start": "electron .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:load": "vitest run --reporter=verbose tests/load.test.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "capture:readme-media": "node ../scripts/capture-readme-media.mjs",
    "rebuild": "electron-rebuild -f -w node-llama-cpp",
    "docs": "typedoc",
    "bump": "npx tsx ../scripts/bump-version.ts",
    "prepare": "cd .. && husky app/.husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,css}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.codeviper.app",
    "productName": "CodeViper",
    "copyright": "Copyright © 2025 roman",
    "npmRebuild": true,
    "buildDependenciesFromSource": false,
    "directories": {
      "buildResources": "resources",
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/node/",
        "to": "node/"
      },
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "shortcutName": "CodeViper",
      "include": "resources/installer.nsh"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "Development"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "darkModeSupport": true
    },
    "dmg": {
      "sign": false
    },
    "publish": {
      "provider": "github",
      "owner": "rkfsociety",
      "repo": "CodeViper",
      "releaseType": "draft"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@tanstack/react-virtual": "^3.14.3",
    "async-mutex": "^0.5.0",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.16.0",
    "node-llama-cpp": "^3.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "systeminformation": "^5.31.11",
    "typescript": "^6.0.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "@eslint/js": "^9.20.0",
    "@playwright/test": "^1.61.0",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gifenc": "^1.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.3",
    "typedoc": "^0.28.19",
    "vite": "^8.1.0",
    "vitest": "^4.1.8"
  }
}
